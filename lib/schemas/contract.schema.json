{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schemaVersion", "goal", "inScope", "acceptanceCriteria", "riskLevel"],
  "if": {
    "properties": { "schemaVersion": { "enum": ["3.2", "3.3", "3.4"] } }
  },
  "then": {
    "required": ["contractId", "status", "timestamps"]
  },
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["3.0", "3.1", "3.2", "3.3", "3.4", "3.5", "3.6", "3.7", "3.8"] },
    "glossaryVersion": { "type": "string", "description": "Version string from project.glossary.json at contract creation time" },
    "contractId": { "type": "string", "pattern": "^sig-.+" },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "completed", "closed", "archived"],
      "default": "draft"
    },
    "timestamps": {
      "type": "object",
      "required": ["createdAt"],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "archivedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "goal": { "type": "string", "minLength": 10 },
    "inScope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "allowNewFilesUnder": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directories where new files may be created"
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "verify"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC[0-9]+$" },
          "description": { "type": "string" },
          "visibility": { "type": "string", "enum": ["visible", "holdout"] },
          "verify": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "value"],
                "properties": {
                  "type": { "type": "string", "enum": ["command", "manual"] },
                  "value": { "type": "string" }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["steps"],
                "properties": {
                  "steps": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "capture": { "type": "string" }
                      },
                      "oneOf": [
                        {
                          "required": ["http"],
                          "properties": {
                            "http": {
                              "type": "object",
                              "required": ["method", "url"],
                              "properties": {
                                "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD"] },
                                "url": { "type": "string" },
                                "headers": { "type": "object", "additionalProperties": { "type": "string" } },
                                "body": {}
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        },
                        {
                          "required": ["exec"],
                          "properties": {
                            "exec": {
                              "type": "object",
                              "required": ["argv"],
                              "properties": {
                                "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        },
                        {
                          "required": ["expect"],
                          "properties": {
                            "expect": {
                              "type": "object",
                              "properties": {
                                "json_path": { "type": "string" },
                                "equals": {},
                                "stdout_contains": { "type": "string" },
                                "stdout_matches": { "type": "string" },
                                "exit_code": { "type": "integer" },
                                "file_exists": { "type": "string" },
                                "file_not_exists": { "type": "string", "description": "Assert that a file/directory does NOT exist (v3.8)" },
                                "source": { "type": "string" }
                              }
                            },
                            "capture": { "type": "string" }
                          }
                        }
                      ]
                    },
                    "minItems": 1
                  },
                  "timeout_ms": { "type": "integer", "minimum": 0 }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "holdoutScenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "verify": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["command"] },
              "value": { "type": "string" }
            }
          }
        }
      },
      "description": "Hidden acceptance criteria not shown to Engineer"
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description", "verify"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["pre", "post", "invariant"] },
          "description": { "type": "string" },
          "verify": { "type": "string" }
        },
        "additionalProperties": false
      },
      "description": "Pre/post conditions and invariants that must hold before, after, or throughout execution"
    },
    "riskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "riskSignals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredInputsProvided": { "type": "boolean" },
    "trust": { "type": "string", "enum": ["local"] },
    "holdoutManifest": {
      "type": "object",
      "required": ["count", "hash"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "hash": { "type": "string" }
      },
      "additionalProperties": false
    },
    "parentContractId": {
      "type": "string",
      "pattern": "^sig-.+",
      "description": "ContractId of the parent contract (for follow-up work)"
    },
    "relatedContractIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sig-.+" },
      "description": "ContractIds of related parallel or dependent contracts"
    },
    "contextInheritance": {
      "type": "object",
      "properties": {
        "projectRef": {
          "type": ["string", "null"],
          "description": "Path or status: string path=loaded, 'not_found'=checked but missing, null=explicit waiver, absent=legacy"
        },
        "projectIntentSha256": {
          "type": "string",
          "description": "SHA-256 of project.intent.md contents at contract creation time"
        },
        "contextSnapshotHash": {
          "type": "string",
          "description": "SHA-256 hex digest over concatenated byte contents of all files listed in staleIfChanged, in array order, computed at contract creation time"
        },
        "staleIfChanged": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Upstream artifact paths whose modification triggers staleness; hash is recomputed over these files during upstream_staleness_check"
        },
        "stalenessStatus": {
          "type": "string",
          "enum": ["fresh", "warning", "stale"],
          "description": "Current staleness state: fresh=hash matches, warning=soft mismatch, stale=hash differs and policy=block"
        },
        "stalenessPolicy": {
          "type": "string",
          "enum": ["block", "warn"],
          "default": "warn",
          "description": "Action when upstream hash differs: block=halt pipeline, warn=emit warning and continue"
        }
      },
      "additionalProperties": true
    },
    "dependsOnContractIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sig-.+" },
      "description": "ContractIds that must complete before this contract can be executed"
    },
    "supersedesContractIds": {
      "type": "array",
      "items": { "type": "string", "pattern": "^sig-.+" },
      "description": "ContractIds that this contract replaces or supersedes"
    },
    "supersededByContractId": {
      "type": "string",
      "pattern": "^sig-.+",
      "description": "ContractId of the contract that supersedes this one"
    },
    "interfacesTouched": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Named interfaces, APIs, or module boundaries touched by this contract"
    },
    "ambiguityCandidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "location", "severity"],
        "properties": {
          "text": { "type": "string" },
          "location": { "type": "string" },
          "severity": { "type": "string" }
        }
      },
      "description": "Ambiguous phrases or requirements identified during ambiguity review pass"
    },
    "contradictionsFound": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_a", "claim_b", "type"],
        "properties": {
          "claim_a": { "type": "string" },
          "claim_b": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "description": "Contradicting claims identified during contradiction review pass"
    },
    "clarificationDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "decision", "rationale"],
        "properties": {
          "question": { "type": "string" },
          "decision": { "type": "string" },
          "rationale": { "type": "string" }
        }
      },
      "description": "Clarification questions resolved inline during critique passes"
    },
    "assumptionProvenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "source", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "type": "string" }
        }
      },
      "description": "Typed provenance records for assumptions (source + confidence level)"
    },
    "readinessForPlanning": {
      "type": "object",
      "required": ["verdict", "summary"],
      "properties": {
        "verdict": { "type": "string", "enum": ["go", "no-go"] },
        "summary": { "type": "string" }
      },
      "description": "Computed gate: go = contract is ready for execution, no-go = requires revision or escalation"
    },
    "removals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "reason", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^RM[0-9]+$" },
          "path": { "type": "string", "description": "Relative path to file or directory to remove" },
          "reason": { "type": "string" },
          "type": { "type": "string", "enum": ["file", "directory"] },
          "replacedBy": { "type": "string", "description": "Path to the replacement (if applicable)" },
          "preventReintroduction": { "type": "boolean", "default": false, "description": "If true, engineer must verify the path does not reappear" },
          "modulesYamlTransition": {
            "type": "string",
            "enum": ["deprecated_to_removed", "active_to_deprecated", "active_to_removed", "none"],
            "description": "What status transition to apply in modules.yaml"
          }
        },
        "additionalProperties": false
      },
      "description": "Files/directories to delete as part of this contract (v3.8)"
    },
    "cleanupObligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "target", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^CO[0-9]+$" },
          "action": {
            "type": "string",
            "enum": ["update_imports", "update_docs", "update_config", "update_manifest", "remove_references", "custom"],
            "description": "Type of cleanup action"
          },
          "target": { "type": "string", "description": "Glob pattern or path for files to clean up" },
          "description": { "type": "string" },
          "blocking": { "type": "boolean", "default": true, "description": "If true, unfulfilled obligation blocks AUTO_OK" },
          "verify": {
            "type": "object",
            "required": ["steps"],
            "properties": {
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "capture": { "type": "string" }
                  },
                  "oneOf": [
                    {
                      "required": ["exec"],
                      "properties": {
                        "exec": {
                          "type": "object",
                          "required": ["argv"],
                          "properties": {
                            "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                          }
                        },
                        "capture": { "type": "string" }
                      }
                    },
                    {
                      "required": ["expect"],
                      "properties": {
                        "expect": {
                          "type": "object",
                          "properties": {
                            "exit_code": { "type": "integer" },
                            "stdout_contains": { "type": "string" },
                            "stdout_matches": { "type": "string" },
                            "file_exists": { "type": "string" },
                            "file_not_exists": { "type": "string" },
                            "source": { "type": "string" }
                          }
                        },
                        "capture": { "type": "string" }
                      }
                    }
                  ]
                },
                "minItems": 1
              },
              "timeout_ms": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "description": "Cleanup actions that must be completed alongside the main task (v3.8, K8s Finalizer semantics)"
    },
    "implementationStrategy": {
      "type": "object",
      "required": ["taskType", "guidance"],
      "properties": {
        "taskType": { "type": "string", "enum": ["bugfix", "feature", "refactor", "security"] },
        "guidance": { "type": "string", "minLength": 1 }
      },
      "description": "Task-type-specific process guidance for the Engineer; optional, informational only"
    }
  }
}
